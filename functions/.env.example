# Cloud Functions config (Firebase params). Copy to `functions/.env` for local
# emulator runs; in CI/deploy these are supplied as environment variables.
#
# The VAPID *public* key — same value as the client's VITE_VAPID_PUBLIC_KEY.
# Not secret (it ships in the browser bundle), so it lives here as a param.
VAPID_PUBLIC_KEY=

# Contact address the push services require. Any mailto you control.
VAPID_SUBJECT=mailto:notifications@rummle.app

# NOTE: the VAPID *private* key is a SECRET, never put it here. Set it with:
#   firebase functions:secrets:set VAPID_PRIVATE_KEY
# (locally the emulator picks it up from `functions/.secret.local`).
