# Firebase web app config. Copy to `.env` and fill in from your Firebase console
# (Project settings -> Your apps -> SDK setup and configuration).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=demo-rummle
VITE_FIREBASE_APP_ID=

# When "true", the app connects to the local Firebase Emulator Suite instead of
# a real project. Great for local dev — no real project needed.
VITE_USE_EMULATOR=true
VITE_EMULATOR_HOST=127.0.0.1
VITE_FIRESTORE_EMULATOR_PORT=8080
VITE_AUTH_EMULATOR_PORT=9099

# Optional: Cloudflare Web Analytics site token. When set, the cookieless beacon
# loads in production builds only (never in dev/emulator). Leave blank to disable.
# Find it in the Cloudflare dashboard under Web Analytics -> your site -> JS snippet.
VITE_CF_ANALYTICS_TOKEN=
