# Firebase web app config. Copy to `.env` and fill in from your Firebase console
# (Project settings -> Your apps -> SDK setup and configuration).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=demo-rummle
VITE_FIREBASE_APP_ID=

# Web Push VAPID *public* key, for "your turn" notifications when the tab is
# closed. Generate a pair with `npx web-push generate-vapid-keys`; the public
# half goes here (and the Cloud Function's VAPID_PUBLIC_KEY), the private half
# becomes the VAPID_PRIVATE_KEY secret. Leave blank to skip closed-tab push —
# in-tab notifications still work without it.
VITE_VAPID_PUBLIC_KEY=

# When "true", the app connects to the local Firebase Emulator Suite instead of
# a real project. Great for local dev — no real project needed.
VITE_USE_EMULATOR=true
VITE_EMULATOR_HOST=127.0.0.1
VITE_FIRESTORE_EMULATOR_PORT=8080
VITE_AUTH_EMULATOR_PORT=9099
